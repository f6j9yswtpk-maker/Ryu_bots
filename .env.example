# Copy this to .env and fill in your values. Never commit .env.

# Wallet private key (dedicated hot wallet only — never your main wallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# CLOB API credentials (auto-derived on first run and saved here)
# Leave blank on first run; the bot will populate these automatically.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Daily reports — ProtonMail SMTP (use an app password from proton.me account)
PROTON_SMTP_PASSWORD=

# Daily reports — X / Twitter (API v2, OAuth 1.0a keys from developer.twitter.com)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Signup / referral link included in tweets and emails
SIGNUP_LINK=https://polymarket.com
